---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Tool's Studio</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
        />

        <!-- PWA Meta Tags -->
        <link rel="manifest" href="/manifest.json" />
        <meta name="theme-color" content="#0b0f19" />
        <link rel="apple-touch-icon" href="/favicon.svg" />
    </head>
    <body class="theme-yt">
        <div class="background-animation"></div>

        <div class="container glass-panel">
            <header>
                <div class="top-bar">
                    <button id="btnDonate" class="text-btn donate-btn"
                        ><i class="fa-solid fa-heart"></i> Donate</button
                    >
                    <button id="btnChangelogs" class="text-btn"
                        ><i class="fa-solid fa-list-ul"></i> Changelogs</button
                    >
                </div>
                <div class="logo-icon">
                    <i class="fa-solid fa-download" id="mainIcon"></i>
                </div>
                <h1>Tool's <span>Studio</span></h1>
                <p id="headerDesc">
                    Download high-quality video and audio seamlessly.
                </p>
            </header>

            <main>
                <div class="tab-navigation">
                    <button class="tab-btn active" id="tabYt"
                        >Grab It All</button
                    >
                    <button class="tab-btn" id="tabBg">Remove BG</button>
                </div>

                <!-- YouTube Downloader Section -->
                <div id="ytSection" class="feature-section active">
                    <div class="input-group">
                        <input
                            type="text"
                            id="urlInput"
                            placeholder="Paste any link here (YT, FB, IG, X, etc)..."
                            autocomplete="off"
                        />
                        <button id="fetchBtn" class="primary-btn">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <span id="fetchText">Fetch</span>
                        </button>
                    </div>

                    <div id="errorMsg" class="error-message"></div>

                    <div id="mediaInfo" class="media-info hidden">
                        <div class="thumbnail-container">
                            <img id="thumbnail" src="" alt="Video Thumbnail" />
                        </div>
                        <div class="details">
                            <h2 id="videoTitle">Video Title</h2>

                            <div class="options-group">
                                <div class="form-control">
                                    <label for="formatType">Format</label>
                                    <select id="formatType">
                                        <option value="mp4">Video (MP4)</option>
                                        <option value="mp3">Audio (MP3)</option>
                                        <!-- Image option added dynamically if available -->
                                    </select>
                                </div>
                                <div class="form-control">
                                    <label for="qualitySelect">Quality</label>
                                    <select id="qualitySelect">
                                        <!-- Dynamically populated -->
                                    </select>
                                </div>
                            </div>

                            <button id="startDownloadBtn" class="action-btn">
                                <i class="fa-solid fa-cloud-arrow-down"></i> Start
                                Processing
                            </button>
                        </div>
                    </div>

                    <div id="progressSection" class="progress-section hidden">
                        <h3 id="statusText">Starting process...</h3>
                        <div class="progress-bar-container">
                            <div id="progressBar" class="progress-bar"></div>
                        </div>
                        <div class="stats">
                            <span id="speedText">--</span>
                            <span id="etaText">--</span>
                        </div>
                    </div>

                    <div id="resultSection" class="result-section hidden">
                        <i class="fa-regular fa-circle-check success-icon"></i>
                        <h3>File Ready!</h3>
                        <a
                            id="downloadLink"
                            href="#"
                            class="download-btn"
                            download
                        >
                            <i class="fa-solid fa-download"></i> Save to Device
                        </a>
                        <button id="newDownloadBtn" class="secondary-btn"
                            >Download Another</button
                        >
                    </div>
                </div>

                <!-- Remove BG Section -->
                <div id="bgSection" class="feature-section">
                    <!-- Model Type Selector -->
                    <div class="model-selector" id="modelSelector">
                        <p class="model-selector-label">Select Image Type</p>
                        <div class="model-options">
                            <button
                                class="model-opt active"
                                data-model="human"
                                id="modelHuman"
                            >
                                <i class="fa-solid fa-user"></i>
                                <span>Human</span>
                                <small>Photo / Portrait</small>
                            </button>
                            <button
                                class="model-opt"
                                data-model="anime"
                                id="modelAnime"
                            >
                                <i class="fa-solid fa-star"></i>
                                <span>Anime</span>
                                <small>Illustration / Art</small>
                            </button>
                            <button
                                class="model-opt"
                                data-model="general"
                                id="modelGeneral"
                            >
                                <i class="fa-solid fa-box"></i>
                                <span>General</span>
                                <small>Object / Product</small>
                            </button>
                        </div>
                    </div>

                    <div class="upload-zone" id="uploadZone">
                        <input
                            type="file"
                            id="fileInput"
                            accept="image/png, image/jpeg, image/jpg, image/webp"
                        />
                        <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                        <h3 class="upload-text">Drag & Drop Image Here</h3>
                        <p class="upload-subtext">
                            or click to browse files (PNG, JPG, WEBP)
                        </p>
                    </div>

                    <div id="bgErrorMsg" class="error-message"></div>

                    <div
                        id="bgLoadingSection"
                        class="bg-result-container hidden"
                    >
                        <i class="fa-solid fa-spinner loading-spinner"></i>
                        <h3 id="bgStatusText">Removing background...</h3>
                    </div>

                    <div
                        id="bgResultSection"
                        class="bg-result-container hidden"
                    >
                        <div class="color-picker-container" id="colorPickerContainer">
                            <p class="color-picker-label">Background Color</p>
                            <div class="color-options">
                                <button class="color-btn active" data-color="transparent" title="Transparent"><i class="fa-solid fa-ban"></i></button>
                                <button class="color-btn" data-color="#ff0000" style="background-color: #ff0000;" title="Red"></button>
                                <button class="color-btn" data-color="#ffff00" style="background-color: #ffff00;" title="Yellow"></button>
                                <button class="color-btn" data-color="#0000ff" style="background-color: #0000ff;" title="Blue"></button>
                                <div class="custom-color-wrapper" title="Custom Color">
                                    <i class="fa-solid fa-palette custom-color-icon"></i>
                                    <input type="color" id="customColorPicker" value="#ffffff" />
                                </div>
                            </div>
                        </div>

                        <div class="slider-container" id="sliderContainer">
                            <img
                                class="bg-result-image slider-img"
                                id="bgResultImage"
                                src=""
                                alt="Removed Background Result"
                            />
                            <img
                                class="slider-img fg"
                                id="fgOriginalImage"
                                src=""
                                alt="Original Image"
                            />
                            <div class="slider-divider" id="sliderDivider">
                            </div>
                            <div class="slider-handle" id="sliderHandle">
                                <i class="fa-solid fa-arrows-left-right"></i>
                            </div>
                        </div>
                        <a
                            id="bgDownloadLink"
                            href="#"
                            class="download-btn"
                            download="removed-bg.png"
                        >
                            <i class="fa-solid fa-download"></i> Save Image
                        </a>
                        <button id="newBgBtn" class="secondary-btn"
                            >Process Another Image</button
                        >
                    </div>
                </div>

                <!-- Local Ad Banner -->
                <div class="ad-banner">
                    <div class="ad-content">
                        <span class="ad-badge">Sponsored</span>
                        <h4>Butuh Jasa Photocopy & Percetakan?</h4>
                        <p>
                            Kunjungi <strong>SMANSA Corner</strong> untuk hasil cepat
                            dan berkualitas.
                        </p>
                    </div>
                    <a
                        href="https://smansacorner.my.id"
                        target="_blank"
                        class="ad-btn"
                    >
                        Kunjungi Web <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>

                <footer style="position: relative;">
                    <p>&copy; 2026 Tool's Studio. All rights reserved.</p>
                    <div
                        class="footer-bottom-container"
                        style="width: 100%; position: relative; display: flex; justify-content: center; align-items: center; margin-top: 0.5rem;"
                    >
                        <div class="footer-links">
                            <button id="btnPrivacy" class="text-btn"
                                >Privacy</button
                            >
                            <span>|</span>
                            <button id="btnTerms" class="text-btn">Terms</button
                            >
                        </div>
                        <div class="dev-links">
                            <a
                                href="https://github.com/SEVENITY"
                                target="_blank"
                                title="GitHub"
                                class="icon-social github"
                            >
                                <i class="fa-brands fa-github"></i>
                            </a>
                            <a
                                href="#"
                                target="_blank"
                                title="Portfolio"
                                class="icon-social portfolio"
                            >
                                <i class="fa-solid fa-briefcase"></i>
                            </a>
                        </div>
                    </div>
                </footer>
            </main>
        </div>

        <!-- Modal Overlay -->
        <div id="infoModal" class="modal-overlay hidden">
            <div class="modal-content glass-panel">
                <div class="modal-header">
                    <h2 id="modalTitle">Title</h2>
                    <button id="closeModal" class="icon-btn"
                        ><i class="fa-solid fa-xmark"></i></button
                    >
                </div>
                <div class="modal-body" id="modalBody">
                    <!-- Dynamic content -->
                </div>
            </div>
        </div>

        <script>
            // @ts-nocheck
            document.addEventListener("DOMContentLoaded", () => {
                // Register Service Worker for PWA
                if ("serviceWorker" in navigator) {
                    navigator.serviceWorker
                        .register("/sw.js")
                        .catch((err) =>
                            console.error(
                                "Service Worker registration failed:",
                                err,
                            ),
                        );
                }

                // Configure Base API URL based on environment
                const API_BASE = import.meta.env.DEV
                    ? "http://localhost:5000"
                    : "https://api.zhogia.my.id";

                const urlInput = document.getElementById("urlInput");
                const fetchBtn = document.getElementById("fetchBtn");
                const fetchText = document.getElementById("fetchText");
                const errorMsg = document.getElementById("errorMsg");

                const mediaInfo = document.getElementById("mediaInfo");
                const thumbnail = document.getElementById("thumbnail");
                const videoTitle = document.getElementById("videoTitle");
                const formatType = document.getElementById("formatType");
                const qualitySelect = document.getElementById("qualitySelect");
                const startDownloadBtn =
                    document.getElementById("startDownloadBtn");

                const progressSection =
                    document.getElementById("progressSection");
                const progressBar = document.getElementById("progressBar");
                const statusText = document.getElementById("statusText");
                const speedText = document.getElementById("speedText");
                const etaText = document.getElementById("etaText");

                const resultSection = document.getElementById("resultSection");
                const downloadLink = document.getElementById("downloadLink");
                const newDownloadBtn =
                    document.getElementById("newDownloadBtn");

                let currentMediaData = null;
                let pollInterval = null;
                let currentTaskId = null;

                // Tab Logic & Feature Switching
                const tabYt = document.getElementById("tabYt");
                const tabBg = document.getElementById("tabBg");
                const ytSection = document.getElementById("ytSection");
                const bgSection = document.getElementById("bgSection");
                const mainIcon = document.getElementById("mainIcon");
                const headerDesc = document.getElementById("headerDesc");

                const switchTab = (activeTab) => {
                    if (activeTab === "yt") {
                        tabYt.classList.add("active");
                        tabBg.classList.remove("active");
                        ytSection.classList.add("active");
                        bgSection.classList.remove("active");
                        document.body.classList.remove("theme-bg");
                        document.body.classList.add("theme-yt");
                        mainIcon.className = "fa-solid fa-download";
                        headerDesc.textContent =
                            "Download high-quality video and audio seamlessly.";
                    } else {
                        tabBg.classList.add("active");
                        tabYt.classList.remove("active");
                        bgSection.classList.add("active");
                        ytSection.classList.remove("active");
                        document.body.classList.remove("theme-yt");
                        document.body.classList.add("theme-bg");
                        mainIcon.className = "fa-solid fa-wand-magic-sparkles";
                        headerDesc.textContent =
                            "Remove background from your images instantly with AI.";
                    }
                };

                tabYt.addEventListener("click", () => switchTab("yt"));
                tabBg.addEventListener("click", () => switchTab("bg"));

                // Remove BG Logic
                const uploadZone = document.getElementById("uploadZone");
                const fileInput = document.getElementById("fileInput");
                const bgErrorMsg = document.getElementById("bgErrorMsg");
                const bgLoadingSection =
                    document.getElementById("bgLoadingSection");
                const bgResultSection =
                    document.getElementById("bgResultSection");
                const bgResultImage = document.getElementById("bgResultImage");
                const fgOriginalImage =
                    document.getElementById("fgOriginalImage");
                const sliderContainer =
                    document.getElementById("sliderContainer");
                const sliderDivider = document.getElementById("sliderDivider");
                const sliderHandle = document.getElementById("sliderHandle");
                const bgDownloadLink =
                    document.getElementById("bgDownloadLink");
                const newBgBtn = document.getElementById("newBgBtn");

                // Model type selector
                let selectedModel = "human";
                const modelOpts = document.querySelectorAll(".model-opt");
                modelOpts.forEach((btn) => {
                    btn.addEventListener("click", () => {
                        modelOpts.forEach((b) => b.classList.remove("active"));
                        btn.classList.add("active");
                        selectedModel = btn.dataset.model;
                    });
                });

                uploadZone.addEventListener("click", () => fileInput.click());

                uploadZone.addEventListener("dragover", (e) => {
                    e.preventDefault();
                    uploadZone.classList.add("dragover");
                });

                uploadZone.addEventListener("dragleave", () => {
                    uploadZone.classList.remove("dragover");
                });

                uploadZone.addEventListener("drop", (e) => {
                    e.preventDefault();
                    uploadZone.classList.remove("dragover");
                    if (e.dataTransfer && e.dataTransfer.files.length) {
                        fileInput.files = e.dataTransfer.files;
                        processImage();
                    }
                });

                fileInput.addEventListener("change", () => {
                    if (fileInput.files.length) processImage();
                });

                const showBgError = (msg) => {
                    bgErrorMsg.textContent = msg;
                    bgErrorMsg.style.display = "block";
                    bgLoadingSection.classList.add("hidden");
                };

                const processImage = async () => {
                    const file = fileInput.files?.[0];
                    if (!file) return;

                    const validTypes = [
                        "image/jpeg",
                        "image/png",
                        "image/jpg",
                        "image/webp",
                    ];
                    if (!validTypes.includes(file.type)) {
                        showBgError(
                            "Unsupported file type. Please upload a PNG, JPG, or WEBP.",
                        );
                        return;
                    }

                    if (file.size > 10 * 1024 * 1024) {
                        showBgError(
                            "Gambar terlalu besar! Maksimal ukuran file adalah 10 MB.",
                        );
                        return;
                    }

                    bgErrorMsg.style.display = "none";
                    uploadZone.classList.add("hidden");
                    document
                        .getElementById("modelSelector")
                        .classList.add("hidden");
                    bgResultSection.classList.add("hidden");
                    bgLoadingSection.classList.remove("hidden");

                    const formData = new FormData();
                    formData.append("image", file);
                    formData.append("model_type", selectedModel);

                    try {
                        const res = await fetch(`${API_BASE}/api/remove-bg`, {
                            method: "POST",
                            body: formData,
                        });

                        const data = await res.json().catch(() => ({}));

                        if (!res.ok) {
                            throw new Error(
                                data.error || "Failed to process image.",
                            );
                        }

                        const fileId = data.file_id;

                        // Simpan ke sessionStorage agar bisa di-restore saat HP sleep/tab switch
                        saveSession({ type: 'bg_result', fileId });

                        // Preview gambar original (dari browser local)
                        const originalUrl = URL.createObjectURL(file);
                        fgOriginalImage.src = originalUrl;

                        // Tampilkan hasil dari server via URL (RAM sudah bebas di server)
                        bgResultImage.src = `${API_BASE}/api/bg-result/${fileId}`;

                        // Link download langsung ke endpoint dengan Content-Disposition
                        bgDownloadLink.href = `${API_BASE}/api/bg-download/${fileId}`;
                        bgDownloadLink.removeAttribute("download");

                        bgLoadingSection.classList.add("hidden");
                        bgResultSection.classList.remove("hidden");
                    } catch (err) {
                        showBgError(err.message);
                        uploadZone.classList.remove("hidden");
                        document
                            .getElementById("modelSelector")
                            .classList.remove("hidden");
                    }
                };

                // Background Color Picker Logic
                const colorBtns = document.querySelectorAll('.color-btn');
                const customColorPicker = document.getElementById('customColorPicker');
                let currentBgColor = 'transparent';

                const updateBgColor = (color) => {
                    currentBgColor = color;
                    
                    // Reset custom picker border
                    customColorPicker.parentElement.style.borderColor = 'rgba(255, 255, 255, 0.2)';
                    customColorPicker.parentElement.classList.remove('active-custom');
                    
                    if (color === 'transparent') {
                        bgResultImage.style.backgroundColor = 'transparent';
                    } else {
                        bgResultImage.style.backgroundColor = color;
                    }

                    // Update download link
                    const baseUrl = bgDownloadLink.href.split('?')[0];
                    if (color === 'transparent') {
                        bgDownloadLink.href = baseUrl;
                        bgDownloadLink.setAttribute("download", "removed-bg.png");
                    } else {
                        const hex = color.replace('#', '');
                        bgDownloadLink.href = `${baseUrl}?color=${hex}`;
                        bgDownloadLink.setAttribute("download", "removed-bg-colored.jpg");
                    }
                };

                colorBtns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        colorBtns.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');
                        updateBgColor(btn.dataset.color);
                    });
                });

                customColorPicker.addEventListener('input', (e) => {
                    colorBtns.forEach(b => b.classList.remove('active'));
                    customColorPicker.parentElement.style.borderColor = 'white';
                    customColorPicker.parentElement.classList.add('active-custom');
                    updateBgColor(e.target.value);
                });

                let isDragging = false;
                const updateSliderPosition = (clientX) => {
                    if (!sliderContainer) return;
                    const rect = sliderContainer.getBoundingClientRect();
                    let x = clientX - rect.left;
                    if (x < 0) x = 0;
                    if (x > rect.width) x = rect.width;
                    const percent = (x / rect.width) * 100;
                    fgOriginalImage.style.clipPath = `polygon(0 0, ${percent}% 0, ${percent}% 100%, 0 100%)`;
                    sliderDivider.style.left = `${percent}%`;
                    sliderHandle.style.left = `${percent}%`;
                };

                const startDrag = (e) => {
                    isDragging = true;
                    updateSliderPosition(
                        e.clientX || (e.touches && e.touches[0].clientX),
                    );
                };

                const stopDrag = () => {
                    isDragging = false;
                };

                const onDrag = (e) => {
                    if (!isDragging) return;
                    e.preventDefault();
                    updateSliderPosition(
                        e.clientX || (e.touches && e.touches[0].clientX),
                    );
                };

                sliderContainer.addEventListener("mousedown", startDrag);
                sliderContainer.addEventListener("touchstart", startDrag, {
                    passive: true,
                });
                window.addEventListener("mouseup", stopDrag);
                window.addEventListener("touchend", stopDrag);
                window.addEventListener("mousemove", onDrag);
                window.addEventListener("touchmove", onDrag, {
                    passive: false,
                });

                newBgBtn.addEventListener("click", () => {
                    clearSession();  // Hapus state tersimpan
                    bgResultSection.classList.add("hidden");
                    bgErrorMsg.style.display = "none";
                    fileInput.value = "";
                    bgResultImage.src = "";
                    fgOriginalImage.src = "";
                    bgDownloadLink.href = "#";
                    uploadZone.classList.remove("hidden");
                    document.getElementById("modelSelector").classList.remove("hidden");

                    // Reset Background Color State
                    colorBtns.forEach(b => b.classList.remove('active'));
                    const transparentBtn = document.querySelector('.color-btn[data-color="transparent"]');
                    if(transparentBtn) transparentBtn.classList.add('active');
                    customColorPicker.parentElement.style.borderColor = 'rgba(255, 255, 255, 0.2)';
                    customColorPicker.parentElement.classList.remove('active-custom');
                    bgResultImage.style.backgroundColor = 'transparent';
                    currentBgColor = 'transparent';

                    // Reset Slider
                    fgOriginalImage.style.clipPath =
                        "polygon(0 0, 50% 0, 50% 100%, 0 100%)";
                    sliderDivider.style.left = "50%";
                    sliderHandle.style.left = "50%";
                });

                // =====================================================
                // SESSION PERSISTENCE — HP Sleep / Tab Switch Recovery
                // =====================================================
                const SESSION_KEY = 'tools_studio_session';

                const saveSession = (data) => {
                    try { sessionStorage.setItem(SESSION_KEY, JSON.stringify(data)); } catch(e) {}
                };

                const loadSession = () => {
                    try { return JSON.parse(sessionStorage.getItem(SESSION_KEY) || 'null'); } catch(e) { return null; }
                };

                const clearSession = () => {
                    try { sessionStorage.removeItem(SESSION_KEY); } catch(e) {}
                };

                // Restore hasil Remove BG dari session
                const restoreBgSession = async (fileId) => {
                    try {
                        const check = await fetch(`${API_BASE}/api/bg-result/${fileId}`);
                        if (!check.ok) { clearSession(); return; } // File sudah expired (>10 menit)

                        // File masih ada - restore UI ke kondisi sebelum sleep
                        switchTab('bg');
                        uploadZone.classList.add('hidden');
                        document.getElementById('modelSelector').classList.add('hidden');
                        bgLoadingSection.classList.add('hidden');
                        bgResultImage.src = `${API_BASE}/api/bg-result/${fileId}`;
                        bgDownloadLink.href = `${API_BASE}/api/bg-download/${fileId}`;
                        bgDownloadLink.removeAttribute('download');
                        bgResultSection.classList.remove('hidden');
                        console.log('[Session] BG result restored dari sessionStorage.');
                    } catch(e) {
                        clearSession(); // Network error / server tidak bisa dijangkau
                    }
                };

                // Resume polling YouTube download dari session
                const resumeYtSession = (taskId) => {
                    currentTaskId = taskId;
                    switchTab('yt');
                    mediaInfo.classList.add('hidden');
                    progressSection.classList.remove('hidden');
                    progressBar.style.width = '50%';
                    statusText.textContent = 'Reconnecting to server...';
                    speedText.textContent = '--';
                    etaText.textContent = '--';
                    if (!pollInterval) {
                        pollInterval = setInterval(() => pollStatus(taskId), 1000);
                    }
                    console.log('[Session] YT download resumed dari sessionStorage.');
                };

                // Cek dan restore state saat page visible
                const checkAndRestoreSession = async () => {
                    const state = loadSession();
                    if (!state) return;
                    if (state.type === 'bg_result' && state.fileId) {
                        // Hanya restore kalau UI sedang tidak menampilkan result (mencegah double load)
                        if (bgResultSection.classList.contains('hidden')) {
                            await restoreBgSession(state.fileId);
                        }
                    } else if (state.type === 'yt_task' && state.taskId) {
                        // Hanya resume kalau polling tidak sedang berjalan
                        if (!pollInterval && resultSection.classList.contains('hidden')) {
                            resumeYtSession(state.taskId);
                        }
                    }
                };

                // Deteksi HP wake up / tab aktif kembali
                document.addEventListener('visibilitychange', () => {
                    if (document.visibilityState === 'visible') {
                        checkAndRestoreSession();
                    }
                });

                // Restore saat halaman pertama kali dimuat (misal: user refresh)
                checkAndRestoreSession();

                // Set default theme class on body
                document.body.classList.add("theme-yt");

                // Modal Logic
                const initModals = () => {
                    const modal = document.getElementById("infoModal");
                    const modalTitle = document.getElementById("modalTitle");
                    const modalBody = document.getElementById("modalBody");
                    const closeModal = document.getElementById("closeModal");

                    const btnDonate = document.getElementById("btnDonate");
                    const btnChangelogs =
                        document.getElementById("btnChangelogs");
                    const btnPrivacy = document.getElementById("btnPrivacy");
                    const btnTerms = document.getElementById("btnTerms");

                    const openModal = (title, contentHTML) => {
                        modalTitle.textContent = title;
                        modalBody.innerHTML = contentHTML;
                        modal.classList.remove("hidden");
                    };

                    closeModal.addEventListener("click", () => {
                        modal.classList.add("hidden");
                    });

                    modal.addEventListener("click", (e) => {
                        if (e.target === modal) modal.classList.add("hidden");
                    });

                    btnDonate.addEventListener("click", () => {
                        openModal(
                            "Support Us",
                            `
                            <p>If you find this tool useful, consider supporting us!</p>
                            <div class="donate-options">
                                <a href="https://ko-fi.com/zhogia" target="_blank" class="donate-card kofi">
